# ─── App ───────────────────────────────────────────────────────────
PORT=3000
APP_URL=http://localhost:3000
SESSION_SECRET=change-this-to-a-long-random-string

# ─── Admin Account ─────────────────────────────────────────────────
ADMIN_EMAIL=joy@rawtalent.com.au
ADMIN_PASSWORD=YourSecurePasswordHere

# ─── Google OAuth (optional but recommended) ───────────────────────
# Get from: https://console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── Google Drive (optional — for cloud backup of articles) ────────
# Base64-encoded service account JSON key
# Get from: Google Cloud → IAM → Service Accounts → Create Key → JSON
# Then run: base64 -i your-key.json | tr -d '\n'
GOOGLE_SERVICE_ACCOUNT_KEY=

# The ID of the Google Drive folder where articles will be stored
# Share this folder with your service account email (Editor access)
DRIVE_FOLDER_ID=
